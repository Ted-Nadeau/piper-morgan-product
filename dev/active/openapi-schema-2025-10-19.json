n":{"schema":{}}}}}}},"/personality-preferences":{"get":{"summary":"Personality Preferences Ui","description":"Serve the personality preferences interface","operationId":"personality_preferences_ui_personality_preferences_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/health/config":{"get":{"summary":"Health Config","description":"Configuration health check endpoint.\n\nReturns validation status for all service configurations.\nCORE-GREAT-2D: Configuration Validation","operationId":"health_config_health_config_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/admin/intent-monitoring":{"get":{"summary":"Intent Monitoring","description":"Intent enforcement monitoring endpoint.\n\nReturns current middleware configuration and monitoring status.\nCORE-GREAT-4B: Intent Enforcement","operationId":"intent_monitoring_api_admin_intent_monitoring_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/admin/intent-cache-metrics":{"get":{"summary":"Intent Cache Metrics","description":"Intent cache performance metrics endpoint.\n\nReturns cache hit rate, size, and performance statistics.\nCORE-GREAT-4B Phase 3: Intent Caching","operationId":"intent_cache_metrics_api_admin_intent_cache_metrics_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/admin/intent-cache-clear":{"post":{"summary":"Clear Intent Cache","description":"Clear the intent cache (admin only).\n\nRemoves all cached intent classifications and resets metrics.\nCORE-GREAT-4B Phase 3: Intent Caching","operationId":"clear_intent_cache_api_admin_intent_cache_clear_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/admin/piper-config-cache-metrics":{"get":{"summary":"Piper Config Cache Metrics","description":"PIPER.md config cache performance metrics endpoint.\n\nReturns cache hit rate, age, and performance statistics for PIPER configuration caching.\nGREAT-4C Phase 3: PIPER Config Caching","operationId":"piper_config_cache_metrics_api_admin_piper_config_cache_metrics_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/admin/piper-config-cache-clear":{"post":{"summary":"Clear Piper Config Cache","description":"Clear the PIPER.md config cache (admin only).\n\nForces next PIPER.md load to read from disk.\nGREAT-4C Phase 3: PIPER Config Caching","operationId":"clear_piper_config_cache_api_admin_piper_config_cache_clear_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/admin/user-context-cache-metrics":{"get":{"summary":"User Context Cache Metrics","description":"User context cache performance metrics endpoint.\n\nReturns cache hit rate and session-level cache statistics.\nGREAT-4C Phase 3: PIPER Config Caching","operationId":"user_context_cache_metrics_api_admin_user_context_cache_metrics_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/admin/user-context-cache-clear":{"post":{"summary":"Clear User Context Cache","description":"Clear the user context cache (admin only).\n\nRemoves all cached user contexts. Next request will reload from PIPER.md.\nGREAT-4C Phase 3: PIPER Config Caching","operationId":"clear_user_context_cache_api_admin_user_context_cache_clear_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/health":{"get":{"summary":"Health","description":"Health check endpoint - exempt from intent enforcement.\n\nReturns basic service status for monitoring and load balancers.","operationId":"health_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/admin/user-context-cache-invalidate/{session_id}":{"post":{"summary":"Invalidate User Context","description":"Invalidate specific user's cached context (admin only).\n\nArgs:\n    session_id: Session identifier to invalidate\n\nGREAT-4C Phase 3: PIPER Config Caching","operationId":"invalidate_user_context_api_admin_user_context_cache_invalidate__session_id__post","parameters":[{"name":"session_id","in":"path","required":true,"schema":{"type":"string","title":"Session Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/integrations/github/status":{"get":{"tags":["github"],"summary":"Github Status","description":"Get GitHub integration status","operationId":"github_status_api_v1_integrations_github_status_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/v1/integrations/slack/status":{"get":{"tags":["slack"],"summary":"Slack Status","description":"Get Slack integration status","operationId":"slack_status_api_v1_integrations_slack_status_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/v1/integrations/notion/status":{"get":{"tags":["notion"],"summary":"Notion Status","description":"Get Notion integration status","operationId":"notion_status_api_v1_integrations_notion_status_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/v1/integrations/calendar/status":{"get":{"tags":["calendar"],"summary":"Calendar Status","description":"Get Calendar integration status","operationId":"calendar_status_api_v1_integrations_calendar_status_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/v1/standup/generate":{"post":{"tags":["standup"],"summary":"Generate Standup","description":"Generate standup in specified mode and format.\n\nThis is the main endpoint for standup generation. It supports 5 modes:\n- standard: Basic standup generation\n- issues: GitHub issues intelligence\n- documents: Document suggestions\n- calendar: Calendar integration\n- trifecta: All intelligence sources\n\nAnd 4 output formats:\n- json: Raw structured data\n- slack: Slack-formatted message\n- markdown: Markdown text\n- text: Plain text\n\nPerformance target: <2s end-to-end\n\nAuthentication (Task 2 vs Task 3):\n- Task 2 (REQUIRE_AUTH=false): Auth optional, uses request.user_id or \"default\"\n- Task 3+ (REQUIRE_AUTH=true): JWT required via Authorization: Bearer header\n\nArgs:\n    request: StandupRequest with mode, format, and optional user_id\n    service: Injected StandupOrchestrationService\n    current_user: Optional JWT claims (None if auth disabled, JWTClaims if enabled)\n\nReturns:\n    StandupResponse with generated standup and metadata\n\nRaises:\n    401: Unauthorized (missing or invalid JWT token when REQUIRE_AUTH=true)\n    422: Validation error (invalid mode/format)\n    500: Internal error (service failure)","operationId":"generate_standup_api_v1_standup_generate_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/StandupRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/StandupResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}},"security":[{"HTTPBearer":[]}]}},"/api/v1/standup/modes":{"get":{"tags":["standup"],"summary":"Get Modes","description":"Get list of supported standup generation modes.\n\nReturns mode names and descriptions for all available generation modes.\nUseful for clients to discover what modes are available.\n\nReturns:\n    ModesResponse with modes list and descriptions","operationId":"get_modes_api_v1_standup_modes_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ModesResponse"}}}}}}},"/api/v1/standup/formats":{"get":{"tags":["standup"],"summary":"Get Formats","description":"Get list of supported output formats.\n\nReturns format names and descriptions for all available output formats.\nUseful for clients to discover what formats are available.\n\nReturns:\n    FormatsResponse with formats list and descriptions","operationId":"get_formats_api_v1_standup_formats_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/FormatsResponse"}}}}}}},"/api/v1/standup/health":{"get":{"tags":["standup"],"summary":"Health Check","description":"Health check endpoint for standup API.\n\nReturns service status and availability information.\nUseful for monitoring and load balancers.\n\nReturns:\n    HealthResponse with status and service info","operationId":"health_check_api_v1_standup_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HealthResponse"}}}}}}}},"components":{"schemas":{"FormatsResponse":{"properties":{"formats":{"items":{"type":"string"},"type":"array","title":"Formats","description":"Supported output formats"},"descriptions":{"additionalProperties":{"type":"string"},"type":"object","title":"Descriptions","description":"Format descriptions"}},"type":"object","required":["formats","descriptions"],"title":"FormatsResponse","description":"Response model for formats endpoint","example":{"descriptions":{"json":"Raw structured data","markdown":"Markdown-formatted text","slack":"Slack-formatted with emoji and sections","text":"Plain text format"},"formats":["json","slack","markdown","text"]}},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"HealthResponse":{"properties":{"status":{"type":"string","title":"Status","description":"Health status"},"service":{"type":"string","title":"Service","description":"Service name"},"timestamp":{"type":"string","title":"Timestamp","description":"Check timestamp"},"modes_available":{"type":"integer","title":"Modes Available","description":"Number of available modes"},"formats_available":{"type":"integer","title":"Formats Available","description":"Number of available formats"}},"type":"object","required":["status","service","timestamp","modes_available","formats_available"],"title":"HealthResponse","description":"Response model for health endpoint"},"ModesResponse":{"properties":{"modes":{"items":{"type":"string"},"type":"array","title":"Modes","description":"Supported generation modes"},"descriptions":{"additionalProperties":{"type":"string"},"type":"object","title":"Descriptions","description":"Mode descriptions"}},"type":"object","required":["modes","descriptions"],"title":"ModesResponse","description":"Response model for modes endpoint","example":{"descriptions":{"calendar":"Standup with calendar integration","documents":"Standup with document suggestions","issues":"Standup with GitHub issues intelligence","standard":"Basic standup generation","trifecta":"All intelligence sources combined"},"modes":["standard","issues","documents","calendar","trifecta"]}},"StandupRequest":{"properties":{"mode":{"type":"string","enum":["standard","issues","documents","calendar","trifecta"],"title":"Mode","description":"Standup generation mode","default":"standard"},"format":{"type":"string","enum":["json","slack","markdown","text"],"title":"Format","description":"Output format","default":"json"},"user_id":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"User Id","description":"User identifier (resolved from config if not provided)"}},"type":"object","title":"StandupRequest","description":"Request model for standup generation.\n\nAttributes:\n    mode: Generation mode (standard, issues, documents, calendar, trifecta)\n    format: Output format (json, slack, markdown, text)\n    user_id: Optional user identifier (resolved from config if not provided)","example":{"format":"slack","mode":"trifecta","user_id":"xian"}},"StandupResponse":{"properties":{"success":{"type":"boolean","title":"Success","description":"Whether generation succeeded"},"standup":{"title":"Standup","description":"Standup content (type varies by format)"},"metadata":{"type":"object","title":"Metadata","description":"Generation metadata"},"performance_metrics":{"type":"object","title":"Performance Metrics","description":"Performance metrics"}},"type":"object","required":["success","standup","metadata","performance_metrics"],"title":"StandupResponse","description":"Response model for standup generation.\n\nAttributes:\n    success: Whether generation succeeded\n    standup: Standup content (format depends on request.format)\n    metadata: Generation metadata (mode, format, user_id, timestamp)\n    performance_metrics: Performance data (generation_time_ms, formatted metrics)","example":{"metadata":{"format":"json","mode":"standard","timestamp":"2025-10-19T14:30:00.123456","user_id":"xian"},"performance_metrics":{"efficiency_multiplier":"947x faster","generation_time_formatted":"0.95s","generation_time_ms":950,"generation_time_with_context":"0.95s (lightning fast ⚡)","time_saved_formatted":"15m saved"},"standup":{"blockers":[],"context_source":"persistent","generated_at":"2025-10-19T14:30:00","github_activity":{},"time_saved_minutes":15,"today_priorities":["Start Phase 2 API"],"user_id":"xian","yesterday_accomplishments":["Completed Phase Z"]},"success":true}},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}},"securitySchemes":{"HTTPBearer":{"type":"http","scheme":"bearer"}}}}
