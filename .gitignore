# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# OAuth credentials (never commit)
token.json
credentials.json

# dependencies
node_modules/
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python virtual environment and cache
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Archive directory for large files and historical assets
docs/archive/

# Development artifacts (session logs, working docs, experiments)
dev/
archive/
trash/

# Test coverage reports
htmlcov/
.coverage

# Database files
*.sqlite3
*.db
data_backup/

# User configuration files (private, not committed)
config/PIPER.user.md
**/PIPER.user.md
*.user.md
docs/comms/blog/*.png
docs/comms/blog/*.jpg
docs/comms/blog/*.jpeg
archive/
*.dmg
*.png
*.docx

# Coordination queue - keep structure but ignore local work files
coordination/claimed/*.tmp
coordination/blocked/*.tmp
advisors/*/outbox/*.tmp

# Git worktrees for multi-agent isolation
# Each agent gets an isolated worktree in .trees/<prompt-id>-<session>/
.trees/
external/ted-multichat/
dev/
.beads/

# Agent mailboxes (local workflow tooling)
mailboxes/
