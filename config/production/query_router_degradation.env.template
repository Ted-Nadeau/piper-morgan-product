# QueryRouter Graceful Degradation Configuration Template
# PM-063: Production-ready circuit breaker and degradation settings

# Circuit Breaker Feature Flag
ENABLE_CIRCUIT_BREAKERS=true

# QueryRouter Circuit Breaker Configuration
QUERY_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
QUERY_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Service-Specific Circuit Breaker Thresholds
PROJECT_SERVICE_CIRCUIT_BREAKER_THRESHOLD=3
FILE_SERVICE_CIRCUIT_BREAKER_THRESHOLD=5
CONVERSATION_SERVICE_CIRCUIT_BREAKER_THRESHOLD=2

# Degradation Behavior Configuration
QUERY_DEGRADATION_ENABLED=true
QUERY_DEGRADATION_USER_FRIENDLY_MESSAGES=true
QUERY_DEGRADATION_STRUCTURED_FILE_RESPONSES=true

# Monitoring and Alerting
QUERY_DEGRADATION_MONITORING_ENABLED=true
QUERY_DEGRADATION_ALERT_ON_CIRCUIT_BREAKER_OPEN=true
QUERY_DEGRADATION_METRICS_COLLECTION=true

# Backward Compatibility
QUERY_ROUTER_TEST_MODE=false

# Operational Settings
QUERY_DEGRADATION_LOG_LEVEL=INFO
QUERY_DEGRADATION_DEBUG_LOGGING=false
