{
  "query_router_degradation_rollout": {
    "description": "PM-063: Gradual rollout configuration for QueryRouter graceful degradation",
    "version": "1.0.0",
    "rollout_strategy": "gradual",
    "stages": [
      {
        "name": "canary",
        "description": "Initial canary deployment - 5% of traffic",
        "percentage": 5,
        "duration_hours": 24,
        "success_criteria": {
          "error_rate_increase": "<2%",
          "response_time_degradation": "<10%",
          "circuit_breaker_false_positives": "<0.1%"
        },
        "rollback_triggers": {
          "error_rate_spike": ">5%",
          "response_time_spike": ">25%",
          "user_complaints": ">3"
        }
      },
      {
        "name": "pilot",
        "description": "Pilot deployment - 25% of traffic",
        "percentage": 25,
        "duration_hours": 48,
        "success_criteria": {
          "error_rate_increase": "<1%",
          "response_time_degradation": "<5%",
          "successful_degradations": ">90%"
        },
        "rollback_triggers": {
          "error_rate_spike": ">3%",
          "response_time_spike": ">15%",
          "degradation_failures": ">10%"
        }
      },
      {
        "name": "gradual",
        "description": "Gradual rollout - 75% of traffic",
        "percentage": 75,
        "duration_hours": 72,
        "success_criteria": {
          "system_stability": "maintained",
          "user_experience": "improved",
          "operational_confidence": "high"
        },
        "rollback_triggers": {
          "stability_regression": "any",
          "user_experience_degradation": "significant"
        }
      },
      {
        "name": "full",
        "description": "Full deployment - 100% of traffic",
        "percentage": 100,
        "duration_hours": "indefinite",
        "success_criteria": {
          "cascade_failure_prevention": "demonstrated",
          "graceful_degradation": "working",
          "monitoring_integration": "operational"
        }
      }
    ],
    "feature_flags": {
      "ENABLE_QUERY_ROUTER_DEGRADATION": true,
      "ENABLE_CIRCUIT_BREAKERS": true,
      "ENABLE_DEGRADATION_MONITORING": true,
      "ENABLE_STRUCTURED_ERROR_RESPONSES": true
    },
    "monitoring": {
      "key_metrics": [
        "query_router_circuit_breaker_state",
        "query_router_degradation_activations",
        "query_router_error_rate",
        "query_router_response_time_p95",
        "user_experience_degradation_score"
      ],
      "alert_thresholds": {
        "circuit_breaker_open_duration": "300s",
        "degradation_activation_rate": "10%",
        "error_rate_spike": "5%",
        "response_time_spike": "25%"
      }
    }
  }
}
