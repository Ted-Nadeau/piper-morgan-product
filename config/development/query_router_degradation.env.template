# QueryRouter Graceful Degradation Configuration Template - Development
# PM-063: Development-friendly circuit breaker and degradation settings

# Circuit Breaker Feature Flag (Relaxed for development)
ENABLE_CIRCUIT_BREAKERS=true

# QueryRouter Circuit Breaker Configuration (More forgiving thresholds)
QUERY_CIRCUIT_BREAKER_FAILURE_THRESHOLD=10
QUERY_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

# Service-Specific Circuit Breaker Thresholds (Higher for development)
PROJECT_SERVICE_CIRCUIT_BREAKER_THRESHOLD=8
FILE_SERVICE_CIRCUIT_BREAKER_THRESHOLD=10
CONVERSATION_SERVICE_CIRCUIT_BREAKER_THRESHOLD=5

# Degradation Behavior Configuration
QUERY_DEGRADATION_ENABLED=true
QUERY_DEGRADATION_USER_FRIENDLY_MESSAGES=true
QUERY_DEGRADATION_STRUCTURED_FILE_RESPONSES=true

# Monitoring and Alerting (Enhanced for development debugging)
QUERY_DEGRADATION_MONITORING_ENABLED=true
QUERY_DEGRADATION_ALERT_ON_CIRCUIT_BREAKER_OPEN=false
QUERY_DEGRADATION_METRICS_COLLECTION=true

# Backward Compatibility
QUERY_ROUTER_TEST_MODE=false

# Operational Settings (More verbose for development)
QUERY_DEGRADATION_LOG_LEVEL=DEBUG
QUERY_DEGRADATION_DEBUG_LOGGING=true
