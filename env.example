# Piper Morgan Environment Variables
# Copy this to .env and customize for your setup

# Database Configuration (PostgreSQL)
# These values match docker-compose.yml defaults
POSTGRES_USER=piper
POSTGRES_PASSWORD=dev_changeme_in_production
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=piper_morgan

# Database SSL Configuration (for production)
# POSTGRES_SSL_MODE=prefer  # Options: disable, prefer, require, verify-ca, verify-full
# POSTGRES_SSL_ROOT_CERT=/path/to/ca-cert.pem
# POSTGRES_SSL_CERT=/path/to/client-cert.pem
# POSTGRES_SSL_KEY=/path/to/client-key.pem

# Application Configuration
APP_DEBUG=false
PORT=8001

# LLM API Keys (stored in OS keychain, not in .env!)
# Use: python main.py keys add <provider> <key>
# Providers: anthropic, openai, google
