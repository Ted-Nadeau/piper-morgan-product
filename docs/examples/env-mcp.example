# MCP Protocol Configuration - PM-033 Infrastructure
# Model Context Protocol settings for consumer and server modes

# ========================================
# MCP Consumer Mode Configuration (PM-033a)
# ========================================

# MCP Client Settings
MCP_CLIENT_ENABLED=true
MCP_CLIENT_TIMEOUT=30
MCP_CLIENT_MAX_RETRIES=3
MCP_CLIENT_POOL_SIZE=10

# MCP Protocol Version
MCP_PROTOCOL_VERSION=1.0
MCP_PROTOCOL_COMPATIBILITY_MODE=strict

# MCP Resource Discovery
MCP_DISCOVERY_ENABLED=true
MCP_DISCOVERY_SERVERS=https://mcp.registry.ai,https://mcp.hub.local
MCP_DISCOVERY_CACHE_TTL=3600

# ========================================
# MCP Tool Federation (PM-033b)
# ========================================

# External MCP Tool Servers
MCP_TOOL_SERVERS=[]
# Example: ["https://tools.mcp.ai", "https://github.mcp.tools"]

# Tool Authentication
MCP_TOOL_AUTH_METHOD=jwt
MCP_TOOL_AUTH_TOKEN=${JWT_ACCESS_TOKEN}

# Tool Performance Settings
MCP_TOOL_TIMEOUT=10
MCP_TOOL_CACHE_ENABLED=true
MCP_TOOL_CACHE_TTL=300

# ========================================
# MCP Bridge Configuration (PM-033c)
# ========================================

# Slack→MCP Bridge Settings
MCP_BRIDGE_SLACK_ENABLED=false
MCP_BRIDGE_SLACK_SERVICES=spatial_intent,attention_model,spatial_memory

# Bridge Performance
MCP_BRIDGE_CACHE_ENABLED=true
MCP_BRIDGE_RATE_LIMIT=1000  # requests per minute

# ========================================
# MCP Server Mode (PM-033d) - Future
# ========================================

# MCP Server Settings (disabled by default)
MCP_SERVER_ENABLED=false
MCP_SERVER_PORT=8002
MCP_SERVER_HOST=0.0.0.0

# MCP Server Authentication
MCP_SERVER_AUTH_ENABLED=true
MCP_SERVER_AUTH_METHOD=jwt
MCP_SERVER_AUTH_ISSUER=https://piper-morgan.ai
MCP_SERVER_AUTH_AUDIENCE=mcp-consumers

# MCP Server Services to Expose
MCP_SERVER_SERVICES=[]
# Future: ["spatial_intelligence", "workflow_orchestration", "pm_intelligence"]

# MCP Server Rate Limiting
MCP_SERVER_RATE_LIMIT_ENABLED=true
MCP_SERVER_RATE_LIMIT_PER_CLIENT=100  # requests per minute

# MCP Server Monitoring
MCP_SERVER_METRICS_ENABLED=true
MCP_SERVER_METRICS_PORT=9090
MCP_SERVER_HEALTH_CHECK_PATH=/mcp/health

# ========================================
# JWT Integration (ADR-011)
# ========================================

# JWT Configuration for MCP Protocol
JWT_ISSUER=https://piper-morgan.ai
JWT_AUDIENCE=["piper-api", "mcp-protocol"]
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MCP-Specific JWT Claims
JWT_MCP_CLAIMS_ENABLED=true
JWT_MCP_PROTOCOL_VERSION_CLAIM=protocol_version
JWT_MCP_PERMISSIONS_CLAIM=mcp_permissions
JWT_MCP_FEDERATION_ENABLED=false

# ========================================
# Development & Testing
# ========================================

# MCP Development Mode
MCP_DEV_MODE=true
MCP_DEV_MOCK_EXTERNAL_SERVICES=false
MCP_DEV_VERBOSE_LOGGING=true

# MCP Testing Settings
MCP_TEST_MODE=false
MCP_TEST_MOCK_RESPONSES=false
MCP_TEST_CAPTURE_TRAFFIC=false

# ========================================
# Security & Compliance
# ========================================

# MCP Security Settings
MCP_SECURITY_TLS_REQUIRED=true
MCP_SECURITY_VERIFY_CERTIFICATES=true
MCP_SECURITY_ENCRYPTION_ENABLED=true
MCP_SECURITY_AUDIT_LOGGING=true

# MCP Compliance
MCP_COMPLIANCE_DATA_RESIDENCY=us-west-2
MCP_COMPLIANCE_PII_FILTERING=true
MCP_COMPLIANCE_GDPR_MODE=false
