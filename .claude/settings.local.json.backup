      "Bash(PYTHONPATH=. python -c \"\nfrom services.queries.query_router import QueryRouter\nfrom services.queries.degradation import QueryDegradationHandler\nprint(''✅ QueryRouter graceful degradation imports working'')\nprint(''✅ PM-063 implementation is accessible'')\nrouter = QueryRouter(None, None, None, test_mode=True)\nstatus = router.get_degradation_status()\nprint(f''✅ Degradation status: {status}'')\n\")",
      "Bash(PYTHONPATH=. python -m pytest tests/integration/test_api_query_integration.py -v)",
