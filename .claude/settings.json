      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(python:*)",
      "Read(//Users/xian/Downloads/**)",
      "Bash(find:*)",
      "Bash(kill:*)",
      "Bash(curl:*)",
      "Bash(sed:*)",
      "Bash(grep:*)",
