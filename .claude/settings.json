{
  "env": {
    "PYTHONPATH": "/default/path",
    "NODE_ENV": "development"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '🚀 SESSION START REMINDERS:\n• Run \"bd ready --json\" to check available work\n• Use Context7 MCP for library APIs (don't guess syntax)'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(gh issue:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(python:*)",
      "Read(//Users/xian/Downloads/**)",
      "Bash(find:*)",
      "Bash(kill:*)",
      "Bash(curl:*)",
      "Bash(sed:*)",
      "Bash(grep:*)",
      "Bash(timeout:*)",
      "Bash(PYTHONPATH=/Users/xian/Development/piper-morgan timeout 10s python -m uvicorn web.app:app --port 8081 --host 127.0.0.1)",
      "Read(//Users/xian/Development/**)",
      "Bash(export PYTHONPATH=:*)",
      "Bash(export PATH=:*)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(echo:*)",
      "Edit(src/**)",
      "Write(docs/**)",
      "Bash(source :*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Edit(**/*.py)",
      "Write(**/*.py)",
      "mcp__serena__search_for_pattern",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__find_symbol"
    ],
    "deny": [
      "Bash(rm -rf :*)",
      "Bash(sudo:*)",
      "Read(.env*)",
      "Read(secrets/**)"
    ],
    "ask": ["Gh push"]
  }
}
