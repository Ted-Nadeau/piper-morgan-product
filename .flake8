[flake8]
max-line-length = 100
extend-ignore =
    # whitespace before ':'
    E203,
    # line too long (handled by black)
    E501,
    # imported but unused
    F401,
    # f-string is missing placeholders
    F541,
    # redefinition of unused
    F811,
    # undefined name
    F821,
    # local variable assigned but never used
    F841,
    # module level import not at top of file
    E402,
    # comparison to True/False
    E712,
    # trailing whitespace
    W291,
    # blank line contains whitespace
    W293,
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    archive/,
    data_backup/,
    uploads/,
    web/assets/,
    web/*.js,
    web/*.html,
    web/*.md,
    *.backup,
    temp_engine_update.py,
    update_engine.py,
    test_*.py,
    tests/test_*.py,
    fix.py,
