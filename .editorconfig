# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Markdown files
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
# Python files
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
# YAML files
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,jsonc}]
# JSON files
indent_style = space
indent_size = 2
insert_final_newline = true

[Makefile]
# Makefiles require tabs
indent_style = tab
